generator client {
  provider            = "prisma-client"
  output              = "prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

// INSERT INTO "TableDescriptor"("tableName","description") VALUES('Test','{}');
// INSERT INTO "TablePermission"("tableName", "groupId", "canDelete", "canInsert", "canQuery", "canRead", "canUpdate") VALUES('Profile', 2, true, true, true, true, true);

model UserKey {
  id         BigInt @id @default(autoincrement())
  identifier String @unique // Contains username or credential id
  method     String // "publickey" ("password not used anymore")
  userId     BigInt
  user       User   @relation(fields: [userId], references: [id])
  // When method == "publickey"
  publicKey  Bytes? // Used to verify challenges

  // When method == "password"  -> the following keys are encrypted with password-derived key (different password than stored in keyData)
  // When method == "publickey" -> the following keys are encrypted with the keypair
  version Int // Version of sign and data keys

  encryptedPrivateSignKey      Bytes
  encryptedPrivateSignKeyNonce Bytes

  encryptedPrivateDataKey      Bytes
  encryptedPrivateDataKeyNonce Bytes

  // @@unique([userId, method])
}

model User {
  id                   BigInt     @id @default(autoincrement())
  // userName             String     @unique
  personalGroup        Group      @relation(fields: [personalGroupId], references: [id])
  personalGroupId      BigInt     @unique
  personalCollection   Collection @relation(fields: [personalCollectionId], references: [id])
  personalCollectionId BigInt     @unique

  tokenCounter Int @default(0)

  publicSignKey Bytes
  publicDataKey Bytes

  groups          GroupUser[]
  userKeys        UserKey[]
  groupUserKeys   GroupUserKey[]
  groupLogEntries GroupLogEntry[]
}

model GroupUser {
  userId  BigInt
  user    User   @relation(fields: [userId], references: [id])
  groupId BigInt
  group   Group  @relation(fields: [groupId], references: [id])

  role GroupRole

  @@id([userId, groupId])
}

enum GroupRole {
  Reader
  Moderator // Can add/remove users to the group, but not moderators
  Admin // Can add/remove users, including moderators and delete the group
}

// Contains group public key and private key encrypted for user
model GroupUserKey {
  userId  BigInt
  user    User   @relation(fields: [userId], references: [id])
  groupId BigInt
  group   Group  @relation(fields: [groupId], references: [id])

  version             Int
  publicKey           Bytes // TODO: stored public key in shared model (is reused for a lot of GroupUserKey)
  encryptedPrivateKey Bytes // Encrypted using user public key
  // encryptedUsingKeyVersion Int // User keypair cannot change

  @@id([userId, groupId, version])
}

// When a user is removed from a group:
// -> The group keypair must be regenerated
// -> The new keypair is encrypted for each remaining user
// -> Store a signed hash of the remaining users, including their public key, role and user id
// -> Each collection under the group must be flagged as 'to-be-key-rotated'
// -> Each object under the group collections must be flaged as 'to-be-key-rotated'
// -> The old keypair must also be stored so that remaining collections can still can decrypt and update the previous private key
model Group {
  id BigInt @id @default(autoincrement())

  personalUser User? @relation()

  //! Keypair is stored in GroupUserKey
  name             String
  latestKeyVersion Int    @default(1)
  // Only used in public groups:
  // exposedPrivateKey Bytes?

  canCreateCollections Boolean @default(false)

  log                 GroupLogEntry[]
  users               GroupUser[]
  collections         GroupCollection[]
  permissions         TablePermission[]
  keys                GroupUserKey[]
  groupCollectionKeys GroupCollectionKey[]
}

// enum GroupAction {
//   Created
//   KeyRotated
//   UserAdded
//   UserRemoved
// }

model GroupLogEntry {
  sequence     Int    @default(autoincrement())
  groupId      BigInt
  group        Group  @relation(fields: [groupId], references: [id])
  payload      Bytes
  signature    Bytes
  actingUserId BigInt
  actingUser   User   @relation(fields: [actingUserId], references: [id])

  @@id([sequence, groupId])
}

model GroupCollection {
  groupId      BigInt
  group        Group      @relation(fields: [groupId], references: [id])
  collectionId BigInt
  collection   Collection @relation(fields: [collectionId], references: [id])

  canAdd      Boolean // Can add objects to this collection
  canRemove   Boolean // Can remove objects from this collection
  canWrite    Boolean // Can update objects in this collection
  // canRead     Boolean // Can read objects in this collection
  // canQuery    Boolean // Can query objects from this collection
  canShare    Boolean @default(true) // Can share objects from this collection
  canModerate Boolean // Can add/remove groups/users from this collection and adjust permissions

  @@id([groupId, collectionId])
}

// Contains collection public key and private key encrypted for group
model GroupCollectionKey {
  groupId      BigInt
  group        Group      @relation(fields: [groupId], references: [id])
  collectionId BigInt
  collection   Collection @relation(fields: [collectionId], references: [id])

  version                  Int
  publicKey                Bytes // TODO: stored public key in shared model (is reused for a lot of GroupCollectionKey)
  encryptedPrivateKey      Bytes // Encrypted using group public key
  encryptedUsingKeyVersion Int // The private key is encrypted with this GroupUserKey version

  @@id([groupId, collectionId, version])
}

// When a group is removed from a collection (or the collection is marked to be key-rotated)
// -> The collection keypair must be regenerated
// -> The new private key is encrypted for each remaining group
// -> TODO: store a signed signature of the remaining groups, otherwise the server can fake it
// -> Each object in the collection must be flaged as 'to-be-key-rotated'
// -> The old keypair must also be stored so that remaining objects can still can decrypt and update the previous key
model Collection {
  id      BigInt             @id @default(autoincrement())
  groups  GroupCollection[]
  objects CollectionObject[]

  name             String
  latestKeyVersion Int    @default(1)
  //! Keypair is stored in GroupCollectionKey

  personalUser User?                @relation()
  keys         GroupCollectionKey[]
}

model CollectionObject {
  collectionId BigInt
  collection   Collection @relation(fields: [collectionId], references: [id])
  objectId     BigInt
  object       Object     @relation(fields: [objectId], references: [id])

  encryptedObjectKey       Bytes // Encrypted using Collection public key
  encryptedUsingKeyVersion Int

  @@id([collectionId, objectId])
  @@index([collectionId])
}

// When an object is removed from a collection (or the object is marked to be key-rotated):
// -> A new key is generated and encrypted for each remaining collection
// -> The object is re-encrypted with the new key
// -> A list of collection ids is also stored in the encrypted data so that the server can't fake it
model Object {
  id         BigInt          @id @default(autoincrement())
  tableName  String // User specified type of the object, eg "ShoppingItem", "UserProfile"
  table      TableDescriptor @relation(fields: [tableName], references: [tableName])
  data       Bytes // per column contains: list of collection ids it is shared with and version number of data key
  nonce      Bytes
  publicData Json? // You can add indices on specific json fields using postgres create index

  collections CollectionObject[]

  @@index([tableName])
}

model TableDescriptor {
  tableName   String            @id @unique
  description Json
  objects     Object[]
  permissions TablePermission[]
}

model TablePermission {
  tableName String
  groupId   BigInt

  canInsert    Boolean
  canDelete    Boolean
  canUpdate    Boolean
  canRead      Boolean
  // canQuery     Boolean
  // canShare     Boolean
  readColumns  String[]
  writeColumns String[]

  group Group           @relation(fields: [groupId], references: [id])
  table TableDescriptor @relation(fields: [tableName], references: [tableName])

  @@id([groupId, tableName])
}

